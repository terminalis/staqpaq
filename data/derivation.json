  "implications": {
    "database.provider:supabase": [
      "Supabase bundles Postgres, Auth, Storage, and Realtime ? a separate auth / storage / realtime provider may be redundant.",
      "Use Supabase publishable keys for new public clients; legacy anon JWT keys are compatibility-only."
    ],
    "database.provider:firebase": [
      "Firebase bundles Firestore, Auth, Storage, and Functions under one project."
    ],
    "database.provider:convex": [
      "Convex bundles a reactive database, server functions, file storage, and auth — a separate provider for those may be redundant."
    ],
    "database.provider:appwrite": [
      "Appwrite bundles databases, auth, storage, and functions under one self-hostable project."
    ],
    "database.provider:pocketbase": [
      "PocketBase is a single Go binary bundling an embedded SQLite database, auth, file storage, and realtime."
    ],
    "auth.provider:clerk": [
      "Clerk ships prebuilt sign-in UI and session management; protect routes with its middleware."
    ],
    "auth.provider:supabase_auth": [
      "Supabase Auth shares the Supabase project ? no separate auth env vars beyond the Supabase URL and publishable key."
    ],
    "payments.provider:stripe": [
      "Stripe needs a webhook endpoint to reconcile subscription state — wire STRIPE_WEBHOOK_SECRET."
    ],
    "ai.providers:anthropic": [
      "Keep ANTHROPIC_API_KEY server-side only; never expose it to the browser bundle."
    ],
    "deployment.host:github_pages": [
      "GitHub Pages serves static files only — a server runtime, if needed, must live elsewhere."
    ]
  },
  "assets": [
    {
      "asset_id": "logo_primary",
      "label": "Primary logo (wordmark / lockup)",
      "filename_hint": "logo.svg",
      "brand_key": "logo",
      "when": [
        {
          "path": "project.type",
          "present": true
        }
      ]
    },
    {
      "asset_id": "favicon",
      "label": "Favicon",
      "filename_hint": "favicon.ico",
      "brand_key": "favicon",
      "when": [
        {
          "path": "project.platforms",
          "anyOf": [
            "web"
          ]
        }
      ]
    },
    {
      "asset_id": "og_image",
      "label": "Social / OG share image (1200×630)",
      "filename_hint": "og-image.png",
      "brand_key": "social_image",
      "when": [
        {
          "path": "project.platforms",
          "anyOf": [
            "web"
          ]
        }
      ]
    },
    {
      "asset_id": "app_icon_ios",
      "label": "iOS app icon (1024×1024)",
      "filename_hint": "icon-ios.png",
      "brand_key": "app_icon",
      "when": [
        {
          "path": "project.platforms",
          "anyOf": [
            "ios"
          ]
        }
      ]
    },
    {
      "asset_id": "app_icon_android",
      "label": "Android adaptive icon (432×432)",
      "filename_hint": "icon-android.png",
      "brand_key": "app_icon",
      "when": [
        {
          "path": "project.platforms",
          "anyOf": [
            "android"
          ]
        }
      ]
    },
    {
      "asset_id": "app_icon_desktop",
      "label": "Desktop app icon (ICO + ICNS)",
      "filename_hint": "icon-desktop.png",
      "brand_key": "app_icon",
      "when": [
        {
          "path": "project.platforms",
          "anyOf": [
            "macos",
            "windows",
            "linux"
          ]
        }
      ]
    },
    {
      "asset_id": "mobile_splash",
      "label": "Mobile splash screen",
      "filename_hint": "splash.png",
      "brand_key": "splash",
      "when": [
        {
          "path": "project.platforms",
          "anyOf": [
            "ios",
            "android"
          ]
        }
      ]
